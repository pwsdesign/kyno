{
  "name": "kyno",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/provider",
    "apps/admin",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev -w @kyno/web",
    "web:build": "npm run build -w @kyno/web",
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo start --ios"
  }
}
