# Kyno — Environment Variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored and safe for secrets.

# ── AI Insights (optional) ───────────────────────────────────────────────────
# Enables live Claude-powered care recommendations on the home screen.
# Without this, the app uses smart hardcoded defaults (indistinguishable in a demo).
# Get a key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=

# ── Signup form notifications ────────────────────────────────────────────────
# Used by api/signup.js (Vercel serverless function).
# Without these, signups still log to Vercel function logs but no email is sent.
#
# RESEND_API_KEY     — from resend.com (free tier: 3,000 emails/month)
# KYNO_NOTIFY_EMAIL  — the address that receives each signup alert
RESEND_API_KEY=
KYNO_NOTIFY_EMAIL=

# ── Supabase server access ───────────────────────────────────────────────────
# Used by api/membership-pass.js to verify users and store the generated pass URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Public web URL ───────────────────────────────────────────────────────────
# Used when storing the absolute Wallet pass URL on the member profile.
KYNO_PUBLIC_WEB_URL=https://your-kyno-web-app.vercel.app

# ── Apple Wallet signing ─────────────────────────────────────────────────────
# Required to generate a real signed .pkpass file.
APPLE_WALLET_TEAM_IDENTIFIER=
APPLE_WALLET_PASS_TYPE_IDENTIFIER=pass.pet.kyno.membership
APPLE_WALLET_PASS_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
APPLE_WALLET_PASS_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_WALLET_PASS_KEY_PASSWORD=
